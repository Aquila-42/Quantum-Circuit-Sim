import numpy as np
import re
import itertools
from math import sqrt, e, pi, log

class Gate:
    i_ = complex(0, 1)
    H = 1./sqrt(2) * np.matrix('1 1; 1 -1') 
    X = np.matrix('0 1; 1 0')
    Y = np.matrix([[0, -i_], [i_, 0]])
    Z = np.matrix([[1, 0], [0, -1]])
    S = np.matrix([[1, 0], [0, i_]])
    T = np.matrix([[1, 0], [0, e**(i_*pi/4.)]])
    eye = np.eye(2, 2)

    @staticmethod
    def get_cnot(size, ctrl, targ):
        dim = 2**size
        matrix = np.eye(dim, dim)
        for i in range(dim):
            binary = list(format(i, f'0{size}b'))
            if binary[ctrl] == '1':
                binary[targ] = '1' if binary[targ] == '0' else '0'
                swap_idx = int("".join(binary), 2)
                matrix[i], matrix[swap_idx] = np.eye(dim, dim)[swap_idx], np.eye(dim, dim)[i]
        return np.matrix(matrix)

class QuantumComputer:
    def __init__(self, n_qubits=5):
        self.n = n_qubits
        self.state = np.zeros((2**n_qubits, 1), dtype=complex)
        self.state[0] = 1

    def apply_gate(self, gate, q_idx):
        op = gate if q_idx == 0 else Gate.eye
        for i in range(1, self.n):
            op = np.kron(op, gate if i == q_idx else Gate.eye)
        self.state = op * self.state

    def apply_cnot(self, ctrl, targ):
        gate = Gate.get_cnot(self.n, ctrl, targ)
        self.state = gate * self.state

    def execute(self, program):
        # Improved parser: splits by semicolon, strips comments, and handles whitespace
        for line in program.split(';'):
            # Strip comments (everything after #) and whitespace
            instruction = line.split('#')[0].strip()
            if not instruction: 
                continue
            
            if instruction.startswith('cx'):
                # Handle cx q[0], q[1]
                bits = [int(b) for b in re.findall(r'\d+', instruction)]
                self.apply_cnot(bits[0], bits[1])
            else:
                # Handle single qubit gates like h q[0]
                parts = instruction.split()
                if len(parts) < 2: continue
                cmd = parts[0].lower()
                target_str = parts[1]
                idx = int(re.search(r'\d+', target_str).group())
                
                gate_map = {'h': Gate.H, 'x': Gate.X, 'y': Gate.Y, 'z': Gate.Z, 's': Gate.S, 't': Gate.T}
                if cmd in gate_map:
                    self.apply_gate(gate_map[cmd], idx)

    def report(self, title="Simulation Result"):
        print(f"\n--- {title} ---")
        probs = [float((x * x.conjugate()).real) for x in np.array(self.state).flatten()]
        found = False
        for i, p in enumerate(probs):
            if p > 0.0001:
                binary = format(i, f'0{self.n}b')
                bar = '#' * int(p * 20)
                print(f"|{binary}> : {p*100:6.2f}% [{bar}]")
                found = True
        if not found: print("No states with measurable probability.")
        print("-" * (len(title) + 8))

# --- Experiments ---

# GHZ: All 3 qubits become 0 or all become 1
ghz_code = "h q[0]; cx q[0], q[1]; cx q[1], q[2];"

# Teleportation: We prepare q[0] in a specific state and move it to q[2]
# q[0] is the state to send, q[1] and q[2] are the entangled channel.
teleport_code = """
    h q[0]; t q[0];        # State to teleport
    h q[1]; cx q[1], q[2]; # Entangled Bell Pair
    cx q[0], q[1]; h q[0]; # Measurement prep
"""

if __name__ == "__main__":
    # Run GHZ
    sim_ghz = QuantumComputer(n_qubits=3)
    sim_ghz.execute(ghz_code)
    sim_ghz.report("GHZ Entanglement")

    # Run Teleportation
    sim_tp = QuantumComputer(n_qubits=3)
    sim_tp.execute(teleport_code)
    sim_tp.report("Quantum Teleportation (Intermediate)")
